# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/

# Node / frontend
node_modules/
dist/
build/
.env
.env.local

# Data (large files — do not commit raw datasets)
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/*.db
ml/models/*.pkl
ml/models/*.pt
ml/models/*.h5
ml/models/*.ubj
ml/models/*.json
# Exception: the trained fraud model artifacts are committed directly for team
# handoff (they are small and skip retraining). Any other *.json under
# ml/models/ stays ignored; regeneration via ml/models/train_fraud_model.py
# remains available if fresh weights are ever wanted.
!ml/models/fraud_model.json
!ml/models/fraud_model_meta.json
!ml/models/fraud_model_hardened.json
!ml/models/fraud_model_hardened_meta.json

# OS / editor
.DS_Store
.vscode/
.idea/

# Secrets
*.pem
*.key
secrets.json
paysim1.zip
*.zip
